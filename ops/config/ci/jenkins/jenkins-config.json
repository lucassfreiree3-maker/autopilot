      "groovy_sandbox": ["Use @NonCPS for non-serializable operations", "Request script approval from admin"],
      "workspace_issues": ["Clean workspace in post block", "Check disk space", "Use cleanWs() step"],
      "credential_not_found": ["Verify credential ID matches", "Check credential scope (global vs folder)", "Verify domain restrictions"]
