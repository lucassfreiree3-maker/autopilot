{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "bypassPermissions",
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./credentials/**)",
      "Read(./*.pem)",
      "Read(./*.key)",
      "Read(~/.ssh/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.aws/**)",
      "Read(~/.kube/config)",
      "Read(~/.docker/config.json)",
      "Read(~/.npmrc)",
      "Read(~/.azure/**)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "network": {
      "allowedDomains": [
        "github.com",
        "api.github.com",
        "*.githubusercontent.com",
        "registry.npmjs.org",
        "*.npmjs.org",
        "registry.yarnpkg.com",
        "pypi.org",
        "files.pythonhosted.org",
        "go.dev",
        "proxy.golang.org",
        "crates.io",
        "index.crates.io",
        "packages.nuget.org",
        "hub.docker.com",
        "registry-1.docker.io",
        "pkg-containers.githubusercontent.com",
        "gitlab.com",
        "*.docker.io",
        "*.microsoft.com",
        "*.visualstudio.com"
      ]
    }
  },
  "attribution": {
    "commit": "",
    "pr": ""
  }
}
