    "oidc_federation": {
      "description": "Recommended: GitHub Actions OIDC → GCP Workload Identity (no keys)",
      "setup_steps": [
        "1. Create Workload Identity Pool in GCP",
        "2. Create OIDC Provider linked to GitHub",
        "3. Grant roles to the pool principal on GCP resources",
