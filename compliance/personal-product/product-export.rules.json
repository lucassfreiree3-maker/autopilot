{
  "schemaVersion": 2,
  "requiredRepoFiles": [
    "README.md",
    "CLAUDE.md",
    "schemas/workspace.schema.json",
    "schemas/release-state.schema.json",
    "contracts/shared-agent-contract.json"
  ],
  "forbiddenPathGlobs": [
    "secrets/**",
    "reports/**",
    "cache/**",
    "repos/**",
    "**/*.secure.txt",
    "**/*.sqlite",
    "**/*.sqlite-*"
  ],
  "forbiddenContentPatterns": [
    { "name": "oauth_github_token", "pattern": "gho_[A-Za-z0-9_]{20,}" },
    { "name": "classic_github_pat", "pattern": "ghp_[A-Za-z0-9]{20,}" },
    { "name": "fine_grained_github_pat", "pattern": "github_pat_[A-Za-z0-9_]{20,}" },
    { "name": "private_key", "pattern": "-----BEGIN [A-Z ]*PRIVATE KEY-----" },
    { "name": "local_user_home", "pattern": "(?i)C:\\\\Users\\\\[^\\\\\\r\\n]+" },
    { "name": "corporate_onedrive_hint", "pattern": "OneDrive" }
  ]
}
