  "api_patterns": {
    "trigger_build": "curl -X POST ${JENKINS_URL}/job/<NAME>/build --user ${JENKINS_USER}:${JENKINS_TOKEN}",
    "get_build_info": "curl ${JENKINS_URL}/job/<NAME>/<BUILD>/api/json --user ${JENKINS_USER}:${JENKINS_TOKEN}",
    "get_console_log": "curl ${JENKINS_URL}/job/<NAME>/<BUILD>/consoleText --user ${JENKINS_USER}:${JENKINS_TOKEN}",
    "get_queue": "curl ${JENKINS_URL}/queue/api/json --user ${JENKINS_USER}:${JENKINS_TOKEN}"
  },
  "template_location": "ops/templates/ci/jenkinsfile-template.groovy",
