{
  "schemaVersion": 2,
  "description": "Private strict export policy for company machines. Use this file outside the personal/public repository only.",
  "textFileExtensions": [
    ".md",
    ".txt",
    ".ps1",
    ".cmd",
    ".json",
    ".yaml",
    ".yml",
    ".toml",
    ".sh"
  ],
  "excludeGlobs": [
    ".git/**",
    "node_modules/**",
    "cache/**",
    "repos/**",
    "reports/**",
    "logs/**",
    "state/**",
    "secrets/**",
    "**/*.secure.txt",
    "**/*.sqlite",
    "**/*.sqlite-*",
    "**/*.zip",
    "**/*.tar",
    "**/*.tgz",
    "**/*.log"
  ],
  "watchIgnorePrefixes": {
    "persistent": [
      "cache",
      "repos",
      "reports",
      "logs",
      "state",
      "secrets"
    ],
    "workspace": [
      "ai-sync"
    ]
  },
  "pathRedactions": [
    {
      "pattern": "(?i)C:\\\\Users\\\\[^\\\\\\r\\n]+",
      "replacement": "<LOCAL_USER_HOME>"
    },
    {
      "pattern": "OneDrive - [^\\\\\\r\\n]+",
      "replacement": "<CORPORATE_ONEDRIVE>"
    },
    {
      "pattern": "YourCompany",
      "replacement": "<CUSTOMER_NAME>"
    },
    {
      "pattern": "(?i)[A-Za-z0-9._%+-]+@(?:[A-Za-z0-9-]+\\.)*bb\\.com\\.br",
      "replacement": "<PRIVATE_EMAIL>"
    },
    {
      "pattern": "docker\\.binarios\\.intranet\\.[^\\s\"']+",
      "replacement": "<PRIVATE_REGISTRY>"
    },
    {
      "pattern": "https://github\\.com/[A-Za-z0-9_.-]+/",
      "replacement": "https://github.com/<OWNER>/"
    },
    {
      "pattern": "https://github\\.com\\.mcas\\.ms/[A-Za-z0-9_.-]+/",
      "replacement": "https://github.com/<OWNER>/"
    },
    {
      "pattern": "(?i)(?:https?://)?[A-Za-z0-9._-]+(?:\\.[A-Za-z0-9._-]+)*\\.mcas\\.ms[^\\s\"']*",
      "replacement": "<PRIVATE_GITHUB_MIRROR_URL>"
    },
    {
      "pattern": "(?i)(?:https?://)?[A-Za-z0-9._-]+(?:\\.[A-Za-z0-9._-]+)*\\.intranet\\.[^\\s\"']*",
      "replacement": "<PRIVATE_INTERNAL_URL>"
    },
    {
      "pattern": "(?i)(?:https?://)?[A-Za-z0-9._-]+(?:\\.[A-Za-z0-9._-]+)*\\.bb\\.com\\.br[^\\s\"']*",
      "replacement": "<PRIVATE_CORPORATE_URL>"
    }
  ],
  "blockedContentPatterns": [
    {
      "name": "oauth_github_token",
      "pattern": "gho_[A-Za-z0-9_]{20,}"
    },
    {
      "name": "classic_github_pat",
      "pattern": "ghp_[A-Za-z0-9]{20,}"
    },
    {
      "name": "fine_grained_github_pat",
      "pattern": "github_pat_[A-Za-z0-9_]{20,}"
    },
    {
      "name": "private_key",
      "pattern": "-----BEGIN [A-Z ]*PRIVATE KEY-----"
    },
    {
      "name": "local_user_home",
      "pattern": "(?i)C:\\\\Users\\\\[^\\\\\\r\\n]+"
    },
    {
      "name": "private_corporate_domain",
      "pattern": "(?i)(\\.intranet\\.|\\.mcas\\.ms|\\.bb\\.com\\.br)"
    },
    {
      "name": "private_customer_name",
      "pattern": "(?i)YourCompany"
    }
  ],
  "_allowlistNote": "Only export reusable product assets. Keep company-specific runtime roots and stricter deny rules in this private safe-root policy, never in the personal/public repo.",
  "allowlist": []
}
